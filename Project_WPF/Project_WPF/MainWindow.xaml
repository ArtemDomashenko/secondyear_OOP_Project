<Window x:Class="Project_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Project_WPF"
        Title="YouTube Tracker"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <DockPanel>

        <!-- TOP BAR -->
        <Border DockPanel.Dock="Top" Background="#111"
                BorderBrush="#333" BorderThickness="0,0,0,1" Padding="16,0" Height="46">
            <DockPanel>
                <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold">
                    <Run Text="▶ " Foreground="#FF4444"/>
                    <Run Text="YouTube Tracker"/>
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                           Text="{Binding Status}" Foreground="#888"
                           FontSize="11" HorizontalAlignment="Right"/>
                <TabControl x:Name="tabMain" Background="Transparent"
                            BorderThickness="0" HorizontalAlignment="Center">
                    <TabItem Header="Analyze"/>
                    <TabItem Header="History"/>
                    <TabItem Header="Settings"/>
                </TabControl>
            </DockPanel>
        </Border>

        <!-- PAGES -->
        <Grid>

            <!-- ANALYZE -->
            <DockPanel x:Name="pageAnalyze" Margin="20" LastChildFill="True">

                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right" Content="Analyze"
                            Command="{Binding AnalyzeCommand}" Margin="8,0,0,0"/>
                    <Button DockPanel.Dock="Right" Content="▶ Watch"
                            Background="#333" Click="BtnWatch_Click"/>
                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <Border Background="#252525" BorderBrush="#333"
                        BorderThickness="1" CornerRadius="6"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Stretch="Uniform"
                               MaxHeight="360"
                               VerticalAlignment="Top"
                               Source="{Binding LastResult.ThumbnailUrl}"/>

                        <StackPanel Grid.Column="1" Margin="20,20,20,0"
                                    VerticalAlignment="Top">
                            <TextBlock Text="{Binding LastResult.Title}"
                                       FontSize="18" FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Foreground="#888" Margin="0,10,0,4">
                                <Run Text="👁  "/>
                                <Run Text="{Binding LastResult.Views, StringFormat={}{0:N0}}"/>
                                <Run Text="   📅  "/>
                                <Run Text="{Binding LastResult.PublishedUtc, StringFormat={}{0:yyyy-MM-dd}}"/>
                            </TextBlock>
                            <TextBlock Foreground="#666" FontSize="11"
                                       Text="{Binding LastResult.Url}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DockPanel>

            <!-- HISTORY -->
            <Grid x:Name="pageHistory" Margin="20" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,12,10"/>
                <TextBlock Grid.Column="1" Text="Selected" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                <ScrollViewer Grid.Row="1" Grid.Column="0"
                              Margin="0,0,12,0" VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding FilteredItems}"
                             SelectedItem="{Binding Selected}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" BorderBrush="#333"
                                        BorderThickness="1" CornerRadius="6"
                                        Margin="0,0,0,6" ClipToBounds="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Height="62" Stretch="UniformToFill"
                                               Source="{Binding ThumbnailUrl}"/>
                                        <StackPanel Grid.Column="1" Margin="10,8"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" MaxHeight="38"/>
                                            <TextBlock Foreground="#888" FontSize="11" Margin="0,3,0,0"
                                                       Text="{Binding Views, StringFormat=👁  {0:N0}}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="✕"
                                                Background="Transparent"
                                                Foreground="#FF6666"
                                                Padding="0" Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                Tag="{Binding}"
                                                Click="BtnDelete_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Detail panel -->
                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                        Background="#252525" BorderBrush="#333"
                        BorderThickness="1" CornerRadius="6"
                        ClipToBounds="True">
                    <StackPanel>
                        <Image Height="148" Stretch="UniformToFill"
                               Source="{Binding Selected.ThumbnailUrl}"/>
                        <StackPanel Margin="14,12,14,14">
                            <TextBlock Text="{Binding Selected.Title}"
                                       FontWeight="SemiBold" TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <TextBlock Foreground="#888" FontSize="11" Margin="0,0,0,2">
                                <Run Text="👁  "/>
                                <Run Text="{Binding Selected.Views, StringFormat={}{0:N0}}"/>
                            </TextBlock>
                            <TextBlock Foreground="#888" FontSize="11" Margin="0,0,0,14">
                                <Run Text="📅  "/>
                                <Run Text="{Binding Selected.PublishedUtc, StringFormat={}{0:yyyy-MM-dd}}"/>
                            </TextBlock>
                            <Button Content="▶ Watch in Browser"
                                    HorizontalAlignment="Stretch"
                                    Click="BtnWatchSelected_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- SETTINGS -->
            <ScrollViewer x:Name="pageSettings" Margin="20"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="440" HorizontalAlignment="Left">
                    <TextBlock Text="API Settings" FontSize="16"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Enter your RapidAPI credentials."
                               Foreground="#888" Margin="0,0,0,16"/>

                    <Border Background="#252525" BorderBrush="#333"
                            BorderThickness="1" CornerRadius="6" Padding="16">
                        <StackPanel>
                            <TextBlock Text="API Key" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="API Host" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ApiHost, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Base URL" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Language" Foreground="#888" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Hl, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Region" Foreground="#888" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Gl, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Content="Save"
                                    Command="{Binding SaveSettingsCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>