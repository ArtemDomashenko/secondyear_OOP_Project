<Window x:Class="Project_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project_WPF">
    <Window.DataContext>
        <local:MainViewModel xmlns:local="clr-namespace:Project_WPF"/>
    </Window.DataContext>

    <Grid x:Name="grdRoot" Margin="16">
        <TabControl>
            <TabItem Header="Analyze">
                <Grid x:Name="grdAnalyze" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="tbxUrl" Width="640"
                                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Paste YouTube URL or Video ID" TextChanged="tbxUrl_TextChanged"/>
                        <Button x:Name="btnAnalyze" Style="{StaticResource PrimaryButton}"
                                Content="Analyze"
                                Command="{Binding AnalyzeCommand}"/>
                    </StackPanel>

                    <TextBlock x:Name="tblkStatus" Grid.Row="1" Margin="0,10,0,0" Text="{Binding Status}" Opacity="0.85"/>

                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image x:Name="imgThumbnail" Grid.Column="0" Height="140" Stretch="UniformToFill"
                                   Source="{Binding LastResult.ThumbnailUrl}"/>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock x:Name="tblkTitle" Text="{Binding LastResult.Title}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="tblkVideoId" Text="{Binding LastResult.VideoId, StringFormat=Video ID: {0}}" Opacity="0.7" Margin="0,6,0,0"/>
                                <TextBlock x:Name="tblkViews" Text="{Binding LastResult.Views, StringFormat=Views: {0}}" Margin="0,6,0,0"/>
                                <TextBlock x:Name="tblkPublished" Text="{Binding LastResult.PublishedUtc, StringFormat=Published (UTC): {0}}" Margin="0,6,0,0"/>
                                <TextBlock x:Name="tblkUrl" Text="{Binding LastResult.Url, StringFormat=URL: {0}}" TextWrapping="Wrap" Opacity="0.75" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="History">
                <Grid x:Name="grdHistory" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="tbxSearch" Width="360"
                                 Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search by title or id"/>
                        <CheckBox x:Name="cbOnlyFav" Content="Only favourites"
                                  Margin="14,0,0,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding OnlyFav}"/>
                        <Button x:Name="btnExportJson" Style="{StaticResource PrimaryButton}" Content="Export JSON" Command="{Binding ExportJsonCommand}"/>
                        <Button x:Name="btnImportJson" Style="{StaticResource PrimaryButton}" Content="Import JSON" Command="{Binding ImportJsonCommand}"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="lbxHistory" ItemsSource="{Binding ViewItems}"
                                 SelectedItem="{Binding Selected}"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Height="70" Stretch="UniformToFill"
                                                   Source="{Binding ThumbnailUrl}"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding VideoId}" Opacity="0.7"/>
                                                <TextBlock Opacity="0.85">
                                                    <Run Text="Views: "/><Run Text="{Binding Views}"/>
                                                    <Run Text="  |  Published: "/><Run Text="{Binding PublishedUtc}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Favourite, StringFormat=Favourite: {0}}" Opacity="0.7"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Selected" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock x:Name="tblkSelectedTitle" Text="{Binding Selected.Title}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="tblkSelectedVideoId" Text="{Binding Selected.VideoId}" Opacity="0.7"/>
                                <TextBlock x:Name="tblkSelectedViews" Margin="0,8,0,0">
                                    <Run Text="Views: "/><Run Text="{Binding Selected.Views}"/>
                                </TextBlock>
                                <TextBlock x:Name="tblkSelectedPublished">
                                    <Run Text="Published: "/><Run Text="{Binding Selected.PublishedUtc}"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="btnToggleFav" Style="{StaticResource PrimaryButton}" Content="Toggle Fav" Command="{Binding ToggleFavCommand}"/>
                                    <Button x:Name="btnDelete" Style="{StaticResource PrimaryButton}" Content="Delete" Command="{Binding DeleteCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2" Margin="0,10,0,0"
                               Text="Database: youtube_rapid.db  |  JSON: export.json" Opacity="0.7"/>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid x:Name="grdSettings" Margin="12">
                    <StackPanel>
                        <TextBlock Text="RapidAPI Settings" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Paste your RapidAPI key and make sure Host/BaseUrl match the API you subscribed to."
                                   Opacity="0.75" Margin="0,6,0,0"/>

                        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="RapidAPI Key"/>
                                <TextBox x:Name="tbxApiKey" Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="RapidAPI Host" Margin="0,10,0,0"/>
                                <TextBox x:Name="tbxApiHost" Text="{Binding ApiHost, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Base URL" Margin="0,10,0,0"/>
                                <TextBox x:Name="tbxBaseUrl" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <StackPanel Width="200">
                                        <TextBlock Text="hl (language)"/>
                                        <TextBox x:Name="tbxHl" Text="{Binding Hl, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Width="200" Margin="12,0,0,0">
                                        <TextBlock Text="gl (region)"/>
                                        <TextBox x:Name="tbxGl" Text="{Binding Gl, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="btnSaveSettings"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="Save"
                                            Command="{Binding SaveSettingsCommand}"/>
                                </StackPanel>

                                <TextBlock Text="Saved to settings.json in the app folder." Opacity="0.7" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
